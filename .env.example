# GEMINI_API_KEY: Optional. Used for deep cloud-based generative AI analysis.
# If blank/missing, the app falls back to high-fidelity on-device local heuristics instantly.
GEMINI_API_KEY=MY_GEMINI_API_KEY
GITHUB_PAT=YOUR_GITHUB_PERSONAL_ACCESS_TOKEN_HERE

# CODACY_PROJECT_TOKEN: Optional. Used to upload test coverage results to the Codacy dashboard.
# Do not uncomment this placeholder to avoid the Secrets plugin generating empty fields;
# instead, export this token in your local terminal shell or GitHub secrets.
# CODACY_PROJECT_TOKEN=


